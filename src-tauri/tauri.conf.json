{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Private File Organizer",
  "version": "0.1.0",
  "identifier": "com.local.private-file-organizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Private File Organizer",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
